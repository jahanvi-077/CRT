#include<iostream>
using namespace std;
int main(){
    int a;
    int b;
    int c;
    cout<<"enter first , second and third side of a triangle";
    cin>>a>>b>>c;
    if(a+b>c&&a+c>b&&b+c>a)
    {
        cout<<"valid triangle"<<endl;
    }
    else
    {
        cout<<"invalid triangle"<<endl;
    }
    return 0;
}    
    
